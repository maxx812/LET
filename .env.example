NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/live_exam
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace_with_32+_char_secret
JWT_EXPIRY=12h
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
FIREBASE_PROJECT_ID=your-firebase-project-id
ROOM_CAPACITY=100
QUESTION_TOPICS=Marathi Grammar,English Grammar,General Knowledge,Current Affairs,Reasoning,Quantitative Aptitude
CSV_UPLOAD_MAX_BYTES=2097152
SCHEDULER_POLL_INTERVAL_MS=5000
ANSWER_SYNC_INTERVAL_MS=5000
ANSWER_FLUSH_INTERVAL_MS=8000
ANSWER_FLUSH_BATCH_SIZE=250
LEADERBOARD_BROADCAST_INTERVAL_MS=3000
LEADERBOARD_TOP_N=20
QUALIFICATION_COUNT=100
EXAM_RUNTIME_TTL_SECONDS=604800
REQUEST_BODY_LIMIT=1mb
