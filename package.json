{
  "name": "examstrike-monorepo",
  "version": "1.0.0",
  "description": "ExamStrike Project Monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend/admin",
    "frontend/user"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "npm run dev -w backend",
    "dev:user": "npm run dev -w frontend/user",
    "dev:admin": "npm run dev -w frontend/admin",
    "dev": "concurrently -k -n \"BACKEND,USER,ADMIN\" -c \"magenta,cyan,yellow\" \"npm run dev:backend\" \"npm run dev:user\" \"npm run dev:admin\"",
    "build:user": "npm run build -w frontend/user",
    "build:admin": "npm run build -w frontend/admin",
    "build:backend": "npm run build -w backend",
    "lint": "npm run lint -w frontend/user"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
